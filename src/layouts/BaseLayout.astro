---
import GlobalControlsIsland from '../components/GlobalControlsIsland.vue';
import FeedbackWidget from '../components/FeedbackWidget.vue';
import { DEFAULT_OG_IMAGE } from '../utils/seo';

export interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  jsonLd?: object | object[];
  hideControls?: boolean;
  lang?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Read free novels online — fantasy, romance, sci-fi, thriller and more.',
  canonicalUrl,
  jsonLd,
  hideControls = false,
  lang = 'en',
  ogImage = DEFAULT_OG_IMAGE,
} = Astro.props;
const siteTitle = title === 'Home' ? 'Novel Vault — Read Free Novels Online' : `${title} — Novel Vault`;
const resolvedOgImage = ogImage || DEFAULT_OG_IMAGE;
const jsonLdArray = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>{siteTitle}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#faf8f5" />
  {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Novel Vault" />
  <meta property="og:title" content={siteTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={resolvedOgImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={siteTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={resolvedOgImage} />
  {jsonLdArray.map(item => (
    <script type="application/ld+json" set:html={JSON.stringify(item)} />
  ))}
</head>
<body>
  {hideControls ? null : <GlobalControlsIsland client:load />}
  <slot />
  <FeedbackWidget client:load />
  <script>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js').catch(() => {});
    }
  </script>
</body>
</html>
<style is:global>
@import '../styles/global.css';
</style>
