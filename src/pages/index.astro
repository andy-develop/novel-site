---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchIsland from '../components/SearchIsland.vue';
import LiveTelemetryTicker from '../components/vue/LiveTelemetryTicker.vue';
import { getBooks, getEnglishBooks, getAllTags, getTagDisplay } from '../utils/data';
import { getBookUrl, truncateDescription, DEFAULT_OG_IMAGE } from '../utils/seo';

const allBooks = await getBooks();
const books = getEnglishBooks(allBooks);
const tags = getAllTags(books);
const tagCounts: Record<string, number> = {};
for (const t of tags) { tagCounts[t] = books.filter(b => (b.tags || []).includes(t)).length; }

const PER_PAGE = 20;
const page = Math.max(1, parseInt(Astro.url.searchParams.get('page') || '1', 10));
const totalPages = Math.ceil(books.length / PER_PAGE);
const pagedBooks = books.slice((page - 1) * PER_PAGE, page * PER_PAGE);

const description = `Read free English novels online — ${books.length} books across Dark Academia, Romance, Fantasy, Thriller and more at Novel Vault.`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Novel Vault',
  url: 'https://lyriq.space',
  description,
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://lyriq.space/?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};

function cover(title: string) {
  const c = title.charAt(0);
  return /[a-zA-Z]/.test(c) ? c.toUpperCase() : c;
}
---
<BaseLayout title="Home" description={description} canonicalUrl="https://lyriq.space/" jsonLd={jsonLd} ogImage={DEFAULT_OG_IMAGE}>
  <LiveTelemetryTicker client:load />
  <SearchIsland client:load books={books} />

  <!-- SSR visible grid: crawlers and no-JS users see this -->
  <div class="categories">
    <a href="/" class="cat-btn active">All</a>
    {tags.map(t => (
      <a href={`/tag/${encodeURIComponent(t)}`} class="cat-btn">{getTagDisplay(t)} <span class="cat-count">({tagCounts[t]})</span></a>
    ))}
  </div>

  <div class="grid" id="home-grid">
    {pagedBooks.map((book, i) => (
      <a href={getBookUrl(book)} class="novel-card" style={`animation-delay:${i * 0.04}s`} data-astro-prefetch>
        <div class="card-cover">
          <span class="cover-char">{cover(book.title)}</span>
        </div>
        <div class="card-body">
          <div class="title-row">
            <div class="card-title">{book.title}</div>
          </div>
          <div class="card-author">{book.author || 'Unknown'}</div>
          <div class="card-meta">
            {(book.tags || []).slice(0, 3).map(t => <span class="tag-pill">{getTagDisplay(t)}</span>)}
            <span>{book.total_chapters} ch.</span>
          </div>
          {book.intro && <div class="card-intro"><span class="intro-label">Intro:</span> {truncateDescription(book.intro, 120)}</div>}
        </div>
      </a>
    ))}
  </div>

  {totalPages > 1 && (
    <div class="pagination" id="home-pagination">
      <a href={page > 1 ? `/?page=${page - 1}` : undefined} class="page-btn" aria-disabled={page === 1} class:list={['page-btn', { disabled: page === 1 }]}>‹ Prev</a>
      {Array.from({ length: totalPages }, (_, i) => i + 1).map(p => (
        <a href={`/?page=${p}`} class:list={['page-num', { active: p === page }]}>{p}</a>
      ))}
      <a href={page < totalPages ? `/?page=${page + 1}` : undefined} class:list={['page-btn', { disabled: page === totalPages }]}>Next ›</a>
    </div>
  )}
</BaseLayout>

<style>
  .cat-count { font-size: 0.75em; opacity: 0.7; margin-left: 2px; }
  .card-intro {
    font-family: var(--font-body);
    font-size: 0.73rem;
    line-height: 16px;
    height: 16px;
    color: var(--text-muted);
    margin-top: 6px;
    padding: 6px 0 0;
    border-top: 1px solid var(--border);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .intro-label { font-weight: 700; color: var(--gold); font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .novel-card { display:flex; align-items:stretch; text-decoration:none; color:inherit; }
  .page-btn.disabled,
  .page-btn[aria-disabled="true"] {
    pointer-events: none;
    opacity: 0.4;
    cursor: not-allowed;
  }
</style>
