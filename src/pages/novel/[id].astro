---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShelfBtnIsland from '../../components/ShelfBtnIsland.vue';
import { getBooks, getEnglishBooks, findBook, getCatalog, getChapter, getCharacters, getTagDisplay } from '../../utils/data';

const { id } = Astro.params;
const bookId = parseInt(id);
if (!bookId) return Astro.redirect('/404');

const allBooks = await getBooks();
const books = getEnglishBooks(allBooks);
const book = findBook(books, bookId);
if (!book) return Astro.redirect('/404');

const catalog = await getCatalog(bookId);
const chapters = catalog?.chapters || [];
const firstChapter = chapters[0];

const charData = await getCharacters(bookId);
// Convert to sorted array (max 6 characters) for template iteration
const keyCharacters = charData
  ? Object.entries(charData)
      .filter(([, v]) => v.dossier?.epic_nodes?.length > 0)
      .slice(0, 6)
      .map(([id, v]) => ({ id, ...v }))
  : [];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Book",
  "name": book.title,
  "author": { "@type": "Person", "name": book.author || "Unknown" },
  "genre": book.tags,
  "numberOfChapters": book.total_chapters,
  "description": book.intro,
};

const description = book.intro ? book.intro.substring(0, 160) : `Read ${book.title} online for free at Novel Vault.`;
---
<BaseLayout title={book.title} description={description} canonicalUrl={`https://lyriq.space/novel/${bookId}`} jsonLd={jsonLd}>
  <header>
    <div class="header-inner">
      <a href="/" class="logo"><span>N</span>OVEL VAULT</a>
      <span class="header-book-title">{book.title}</span>
    </div>
  </header>

  <div class="reader">
    <a href="/" class="back-btn">← Back to Library</a>

    <h1>{book.title}</h1>
    <div class="detail-title-row">
      <p class="book-author">by {book.author || 'Unknown'}</p>
      <ShelfBtnIsland client:load bookId={bookId} title={book.title} author={book.author || 'Unknown'} totalChapters={book.total_chapters} />
    </div>

    <div class="book-tags">
      {(book.tags || []).map(t => (
        <a href={`/tag/${encodeURIComponent(t)}`} class="tag-pill">{getTagDisplay(t)}</a>
      ))}
    </div>

    {book.intro && <p class="book-intro">{book.intro}</p>}

    {keyCharacters.length > 0 && (
      <div class="characters-section" id="characters-section">
        <h2>Key Characters</h2>
        <div class="char-names-row">
          {keyCharacters.map((char, ci) => (
            <>
              {ci > 0 && <span class="char-dot">·</span>}
              <button class="char-toggle" data-char-idx={ci} aria-expanded="false">
                {char.primary_name}
              </button>
            </>
          ))}
        </div>
        {keyCharacters.map((char, ci) => (
          <div class="char-detail" id={`char-detail-${ci}`}>
            <div class="char-detail-header">
              <span class="char-detail-name">{char.primary_name}</span>
              {char.aliases?.length > 1 && (
                <span class="char-alias">{char.aliases.slice(1).slice(0, 2).join(' · ')}</span>
              )}
            </div>
            <div class="char-nodes">
              {char.dossier.epic_nodes.slice(0, 5).map((node, ni) => (
                <a href={node.url} class="char-node-link" data-astro-prefetch>
                  {node.title.replace(/^📖\s*/, '')}
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    )}

    <div class="chapter-list-section">
      <h2>Chapters ({chapters.length})</h2>
      <ul class="chapter-list">
        {chapters.map(ch => (
          <li>
            <a href={`/novel/${bookId}/${ch.chapter_id}`} data-astro-prefetch>{ch.title}</a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</BaseLayout>

<style>
  .book-author { font-family:var(--font-body); font-size:1.1rem; color:var(--text-dim); margin-bottom:16px; }
  .detail-title-row { display:flex; align-items:center; gap:12px; margin-bottom:16px; }
  .detail-title-row .book-author { margin-bottom:0; }
  .book-tags { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:20px; }
  .book-tags .tag-pill { font-size:0.75rem; cursor:pointer; transition:all 0.15s; }
  .book-tags .tag-pill:hover { background:var(--gold-dim); color:var(--gold); border-color:var(--gold); }
  .book-intro { font-family:var(--font-body); font-size:0.95rem; line-height:1.7; color:var(--text-dim); margin-bottom:28px; }
  .characters-section { margin-bottom:22px; }
  .characters-section h2 { font-family:var(--font-ui); font-size:0.85rem; text-transform:uppercase; letter-spacing:0.06em; color:var(--gold); margin-bottom:8px; }
  .char-names-row { display:flex; align-items:baseline; flex-wrap:wrap; gap:0; }
  .char-dot { color:var(--text-muted); margin:0 6px; font-size:0.9rem; opacity:0.4; }
  .char-toggle { font-family:var(--font-display); font-size:0.88rem; color:var(--text); background:none; border:none; cursor:pointer; padding:2px 1px; border-radius:3px; transition:color 0.15s; outline:none; }
  .char-toggle:hover { color:var(--gold); }
  .char-toggle:focus-visible { box-shadow:0 0 0 2px var(--gold-dim); }
  .char-toggle.active { color:var(--gold); }
  .char-detail { display:none; }
  .char-detail.open { display:block; }
  .char-detail-header { padding:8px 0 2px; display:flex; align-items:baseline; gap:6px; }
  .char-detail-name { font-family:var(--font-display); font-size:0.82rem; color:var(--text); }
  .char-alias { font-family:var(--font-ui); font-size:0.62rem; color:var(--text-muted); }
  .char-nodes { display:flex; flex-wrap:wrap; gap:3px 6px; padding:4px 0 8px; }
  .char-node-link { font-family:var(--font-ui); font-size:0.72rem; color:var(--text-dim); text-decoration:none; padding:3px 8px; border:1px solid var(--border); border-radius:4px; background:var(--bg-card); transition:all 0.15s; white-space:nowrap; }
  .char-node-link:hover { color:var(--gold); border-color:rgba(138,128,104,0.2); background:var(--bg-card-hover); }
  .chapter-list-section h2 { font-family:var(--font-ui); font-size:0.85rem; text-transform:uppercase; letter-spacing:0.06em; color:var(--gold); margin-bottom:12px; }
  .chapter-list { list-style:none; display:flex; flex-direction:column; gap:4px; }
  .chapter-list li a { display:block; padding:8px 12px; border:1px solid var(--border); border-radius:6px; color:var(--text-dim); font-family:var(--font-ui); font-size:0.82rem; transition:all 0.15s; }
  .chapter-list li a:hover { background:var(--bg-card-hover); border-color:rgba(138,128,104,0.2); color:var(--gold); }
</style>
<script>
document.querySelectorAll('.char-toggle').forEach(btn => {
  btn.addEventListener('click', () => {
    const idx = btn.dataset.charIdx;
    const detail = document.getElementById('char-detail-' + idx);
    const isOpen = detail.classList.contains('open');
    document.querySelectorAll('.char-detail.open').forEach(d => d.classList.remove('open'));
    document.querySelectorAll('.char-toggle.active').forEach(b => { b.classList.remove('active'); b.setAttribute('aria-expanded','false'); });
    if (!isOpen) {
      detail.classList.add('open');
      btn.classList.add('active');
      btn.setAttribute('aria-expanded','true');
    }
  });
});
</script>
