---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getBooks, getEnglishBooks, getBooksByTag, getAllTags, getTagDisplay } from '../../utils/data';
import { getBookUrl, buildBreadcrumbList, truncateDescription, slugify } from '../../utils/seo';

const { tag: slug } = Astro.params;
const tag = slug ? decodeURIComponent(slug)
  .split('-')
  .map(w => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase())
  .join(' ')
  .replace('Sci Fi', 'Sci-Fi') : '';
if (!tag) return Astro.redirect('/');

const allBooks = await getBooks();
const books = getEnglishBooks(allBooks);
const tagged = getBooksByTag(books, tag);
if (!tagged.length) return Astro.redirect('/');

const tags = getAllTags(books);
const description = truncateDescription(
  `Browse ${tagged.length} free ${tag} novels online at Novel Vault. Read Dark Academia, Romance, Fantasy, Thriller and more.`,
  160
);

const canonicalUrl = `https://lyriq.space/tag/${slugify(tag)}`;
const breadcrumbSchema = buildBreadcrumbList([
  { name: 'Home', item: 'https://lyriq.space/' },
  { name: `${tag} Novels`, item: canonicalUrl },
]);

function cover(title: string) {
  const c = title.charAt(0);
  return /[a-zA-Z]/.test(c) ? c.toUpperCase() : c;
}
---
<BaseLayout title={`${tag} Novels`} description={description} canonicalUrl={canonicalUrl} jsonLd={breadcrumbSchema}>
  <header>
    <div class="header-inner">
      <a href="/" class="logo"><span>N</span>OVEL VAULT</a>
    </div>
  </header>

  <nav aria-label="breadcrumb" class="breadcrumb">
    <ol>
      <li><a href="/">Home</a></li>
      <li aria-current="page">{tag} Novels</li>
    </ol>
  </nav>

  <div class="tag-page">
    <div class="tag-header">
      <h1>{getTagDisplay(tag)}</h1>
      <span class="tag-count">{tagged.length} {tagged.length === 1 ? 'novel' : 'novels'}</span>
    </div>

    <div class="categories">
      <a href="/" class="cat-btn">All</a>
      {tags.map(t => (
        <a href={`/tag/${slugify(t)}`} class:list={['cat-btn', { active: t === tag }]}>{getTagDisplay(t)}</a>
      ))}
    </div>

    <div class="grid">
      {tagged.map((book, i) => (
        <a href={getBookUrl(book)} class="novel-card" style={`animation-delay:${i*0.04}s`} data-astro-prefetch>
          <div class="card-cover">
            <span class="cover-char">{cover(book.title)}</span>
          </div>
          <div class="card-body">
            <div class="title-row">
              <div class="card-title">{book.title}</div>
            </div>
            <div class="card-author">{book.author || 'Unknown'}</div>
            <div class="card-meta">
              {(book.tags || []).slice(0, 3).map(t => <span class="tag-pill">{getTagDisplay(t)}</span>)}
              <span>{book.total_chapters} ch.</span>
            </div>
            {book.intro && <div class="card-intro"><span class="intro-label">Intro:</span> {truncateDescription(book.intro, 120)}</div>}
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .tag-page { max-width:1100px; margin:0 auto; padding:20px; }
  .tag-header { display:flex; align-items:baseline; gap:12px; margin-bottom:16px; }
  .tag-header h1 { font-family:var(--font-display); font-size:1.8rem; color:var(--gold); font-weight:400; }
  .tag-count { font-family:var(--font-ui); font-size:0.85rem; color:var(--text-dim); }
  .novel-card { display:flex; align-items:stretch; text-decoration:none; color:inherit; }
  .card-intro {
    font-family: var(--font-body);
    font-size: 0.73rem;
    line-height: 1.45;
    color: var(--text-muted);
    margin-top: 6px;
    padding: 6px 0 0;
    border-top: 1px solid var(--border);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .intro-label { font-weight: 700; color: var(--gold); font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .breadcrumb {
    font-family: var(--font-ui);
    font-size: 0.78rem;
    color: var(--text-dim);
    max-width: 1100px;
    margin: 0 auto;
    padding: 12px 20px 0;
  }
  .breadcrumb ol {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .breadcrumb li:not(:last-child)::after {
    content: '/';
    margin-left: 6px;
    color: var(--text-muted);
  }
  .breadcrumb a {
    color: var(--text-dim);
    text-decoration: none;
  }
  .breadcrumb a:hover {
    color: var(--gold);
  }
  .breadcrumb li[aria-current="page"] {
    color: var(--text);
  }
</style>
