---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="empty-state" style="padding-top:20vh;">
    <h1 style="font-family:var(--font-display);font-size:2rem;color:var(--gold);margin-bottom:16px;">404</h1>
    <p>Page not found. <a href="/" style="color:var(--gold);text-decoration:underline;">Return home</a></p>
  </div>
</BaseLayout>
